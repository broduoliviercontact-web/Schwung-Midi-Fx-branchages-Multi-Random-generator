{
    "id": "branchage",
    "name": "Branchage",
    "abbrev": "BG",
    "version": "0.2.0",
    "description": "Grids drum maps with per-lane Branches-style note branching",
    "author": "Mutable Instruments ideas / port for Schwung Move",
    "license": "MIT",
    "dsp": "dsp.so",
    "ui": "branchage_ui.js",
    "api_version": 1,
    "capabilities": {
        "audio_out": false,
        "audio_in": false,
        "midi_in": true,
        "midi_out": true,
        "chainable": true,
        "component_type": "midi_fx",
        "ui_hierarchy": {
            "levels": {
                "root": {
                    "name": "Branchage",
                    "knobs": [
                        "map_x",
                        "map_y",
                        "density_kick",
                        "density_snare",
                        "density_hat",
                        "randomness",
                        "steps",
                        "bpm"
                    ],
                    "params": [
                        "map_x",
                        "map_y",
                        "density_kick",
                        "density_snare",
                        "density_hat",
                        "randomness",
                        "steps",
                        "kick_note",
                        "snare_note",
                        "hat_note",
                        "kick_branch_enabled",
                        "kick_branch_prob",
                        "kick_branch_note",
                        "snare_branch_enabled",
                        "snare_branch_prob",
                        "snare_branch_note",
                        "hat_branch_enabled",
                        "hat_branch_prob",
                        "hat_branch_note",
                        "kick_branch_rand_low",
                        "kick_branch_rand_high",
                        "snare_branch_rand_low",
                        "snare_branch_rand_high",
                        "hat_branch_rand_low",
                        "hat_branch_rand_high",
                        "sync",
                        "bpm"
                    ]
                }
            }
        }
    },
    "chain_params": [
        {
            "key": "map_x",
            "name": "Map X",
            "type": "float",
            "min": 0.0,
            "max": 1.0,
            "default": 0.5,
            "step": 0.01
        },
        {
            "key": "map_y",
            "name": "Map Y",
            "type": "float",
            "min": 0.0,
            "max": 1.0,
            "default": 0.5,
            "step": 0.01
        },
        {
            "key": "density_kick",
            "name": "Kick",
            "type": "float",
            "min": 0.0,
            "max": 1.0,
            "default": 0.5,
            "step": 0.01
        },
        {
            "key": "density_snare",
            "name": "Snare",
            "type": "float",
            "min": 0.0,
            "max": 1.0,
            "default": 0.5,
            "step": 0.01
        },
        {
            "key": "density_hat",
            "name": "Hat",
            "type": "float",
            "min": 0.0,
            "max": 1.0,
            "default": 0.5,
            "step": 0.01
